# Segmentica release config

# Registry with published images. Example:
# SEGMENTICA_IMAGE_PREFIX=ghcr.io/movementip
SEGMENTICA_IMAGE_PREFIX=ghcr.io/movementip
SEGMENTICA_VERSION=2026.04.28

# Public local address
FRONTEND_PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-secret-before-production
AUTH_COOKIE_SECURE=false
AUTH_SESSION_HOURS=12
AUTH_REMEMBER_ME_HOURS=24

# PostgreSQL
POSTGRES_VERSION=17
POSTGRES_DB=Segmentica
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5439

# Tailscale
# Создайте reusable auth key в админке Tailscale и вставьте сюда.
TS_AUTHKEY=
TS_HOSTNAME=segmentica-node
TAILSCALE_WINDOWS_IP=
TAILSCALE_MAC_IP=
TAILSCALE_PUBLIC_HOST=

# Document renderer
DOCUMENT_RENDERER_PORT=3010

# SymmetricDS
SYMMETRIC_ENGINE_NAME=node-mac
SYMMETRIC_HTTP_PORT=31415
SYMMETRIC_PUBLIC_URL=
SYMMETRIC_REGISTRATION_URL=

# Optional remote DB, for multi-node deployments.
REMOTE_DATABASE_URL=
REMOTE_DB_HOST=
REMOTE_DB_PORT=5432
REMOTE_DB_NAME=Segmentica
REMOTE_DB_USER=postgres
REMOTE_DB_PASSWORD=postgres
REMOTE_DB_SSL=false
