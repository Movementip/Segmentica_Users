# Переменные окружения для полного docker-compose запуска

# PostgreSQL снаружи контейнеров доступен на localhost:5439.
# Внутри docker-compose backend и symmetricds используют db:5432.
LOCAL_DATABASE_URL="postgresql://postgres:postgres@localhost:5439/Segmentica"
DATABASE_URL="postgresql://postgres:postgres@localhost:5439/Segmentica"
DB_HOST=localhost
DB_PORT=5439
DB_NAME=Segmentica
DB_USER=postgres
DB_PASSWORD=postgres

# Frontend
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# LibreOffice renderer с хоста доступен на 3010.
# Внутри docker-compose backend ходит к нему по имени сервиса libreoffice:3000.
DOCUMENT_RENDERER_URL=http://localhost:3010

# SymmetricDS
SYMMETRIC_ENGINE_NAME=node-mac
SYMMETRIC_HTTP_PORT=31415
SYMMETRIC_DB_URL=jdbc:postgresql://host.docker.internal:5439/Segmentica
SYMMETRIC_DB_USER=postgres
SYMMETRIC_DB_PASSWORD=postgres

# Обычно эти две переменные можно не задавать:
# - SYMMETRIC_PUBLIC_URL внутри контейнера будет собран автоматически
#   по IP интерфейса tailscale0;
# - SYMMETRIC_REGISTRATION_URL будет собран автоматически из TAILSCALE_WINDOWS_IP.
# Если нужно переопределить вручную, раскомментируйте:
# SYMMETRIC_PUBLIC_URL=http://100.x.y.z:31415
# SYMMETRIC_REGISTRATION_URL=http://100.x.y.z:31415/sync/node-win

# Явная настройка удалённого PostgreSQL на Windows через Tailscale.
# Если не указать эти переменные, backend попробует вывести адрес БД
# из TAILSCALE_WINDOWS_IP/SYMMETRIC_REGISTRATION_URL и возьмёт стандартный порт 5432.
# Этот порт слушает сервис db-tailscale-proxy внутри namespace контейнера Tailscale
# и пересылает трафик в локальный PostgreSQL контейнер db:5432.
# REMOTE_DATABASE_URL="postgresql://postgres:postgres@TAILSCALE_WINDOWS_IP:5432/Segmentica"
# REMOTE_DB_HOST=TAILSCALE_WINDOWS_IP
# REMOTE_DB_PORT=5432
# REMOTE_DB_NAME=Segmentica
# REMOTE_DB_USER=postgres
# REMOTE_DB_PASSWORD=postgres
#
# SSL для PostgreSQL:
# - локальная Docker-БД использует внутреннюю сеть Docker и по умолчанию ходит без PostgreSQL SSL;
# - удалённая БД через Tailscale защищена WireGuard-туннелем и тоже может работать без PostgreSQL SSL;
# - удалённая БД вне Tailscale по умолчанию требует PostgreSQL SSL.
# Для явного управления можно использовать:
# REMOTE_DB_SSL=true
# REMOTE_DB_SSL=false
# или добавить в REMOTE_DATABASE_URL параметр ?sslmode=require / ?sslmode=disable.

# Tailscale
# Используйте актуальный auth key и не коммитьте реальный секрет.
TS_AUTHKEY=tskey-auth-REPLACE_ME
TS_HOSTNAME=segmentica-mac

# Обязателен адрес Windows-ноды в Tailscale.
TAILSCALE_WINDOWS_IP=100.x.y.z

# Быстрый порядок запуска:
# 1. Скопируйте файл в .env.local
# 2. Заполните TS_AUTHKEY и TAILSCALE_WINDOWS_IP
# 3. При необходимости задайте REMOTE_DATABASE_URL явно
# 4. Выполните docker compose up -d --build
